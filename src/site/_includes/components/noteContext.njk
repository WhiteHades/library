{% if pageKind == "note" and relatedIdeas and relatedIdeas.length %}
  <section class="note-context-grid" aria-label="Related reading">
    <div class="note-context-card">
      <div class="note-context-label">Related ideas</div>
      <div class="note-context-links">
        {% for idea in relatedIdeas %}
          <a class="note-context-link" href="{{ idea.url }}">{{ idea.title }}</a>
        {% endfor %}
      </div>
    </div>
  </section>
{% endif %}
