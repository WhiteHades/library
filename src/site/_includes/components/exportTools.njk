<script>
  document.addEventListener("DOMContentLoaded", () => {
    const copyButton = document.querySelector("[data-copy-markdown]");
    const markdownPayload = document.getElementById("note-markdown-payload");

    if (!copyButton || !markdownPayload) return;

    const copyText = async (text) => {
      if (navigator.clipboard && window.isSecureContext) {
        await navigator.clipboard.writeText(text);
        return;
      }

      const textarea = document.createElement("textarea");
      textarea.value = text;
      textarea.setAttribute("readonly", "");
      textarea.style.position = "fixed";
      textarea.style.left = "-9999px";
      document.body.appendChild(textarea);
      textarea.select();
      document.execCommand("copy");
      textarea.remove();
    };

    copyButton.addEventListener("click", async () => {
      try {
        const markdown = JSON.parse(markdownPayload.textContent || '""');
        await copyText(markdown || "");
        copyButton.dataset.state = "done";
        setTimeout(() => {
          copyButton.dataset.state = "";
        }, 1800);
      } catch {
        copyButton.dataset.state = "error";
      }
    });
  });
</script>
