{% if pageKind in ["note", "idea-overview", "series-page"] %}
  <div class="sidebar-export-actions" aria-label="Export actions">
    {% if pageKind in ["note", "idea-overview"] %}
      <button class="sidebar-export-button" type="button" data-copy-markdown>
        <span class="sidebar-export-icon sidebar-export-icon-copy" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="11" height="11" rx="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
        </span>
        <span class="sidebar-export-icon sidebar-export-icon-check" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
        </span>
        <span class="sidebar-export-label">Copy note as Markdown</span>
      </button>
      {% if notePdfUrl %}
      <a class="sidebar-export-button" href="{{ notePdfUrl }}" download>
        <span class="sidebar-export-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"></path><path d="M14 2v6h6"></path><path d="M12 18v-6"></path><path d="m9 15 3 3 3-3"></path></svg>
        </span>
        <span class="sidebar-export-label">Download note as PDF</span>
      </a>
      {% endif %}
      {% if seriesPdfUrl %}
        <a class="sidebar-export-button" href="{{ seriesPdfUrl }}" download>
          <span class="sidebar-export-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M4 4.5A2.5 2.5 0 0 1 6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5z"></path><path d="M8 7h8"></path><path d="M8 11h8"></path></svg>
          </span>
          <span class="sidebar-export-label">Download series as PDF</span>
        </a>
      {% endif %}
      {% if rawNoteMarkdown %}
        <script id="note-markdown-payload" type="application/json">{{ rawNoteMarkdown | jsonStringify | safe }}</script>
      {% endif %}
    {% elif pageKind == "series-page" and seriesPdfUrl %}
      <a class="sidebar-export-button" href="{{ seriesPdfUrl }}" download>
        <span class="sidebar-export-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M4 4.5A2.5 2.5 0 0 1 6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5z"></path><path d="M8 7h8"></path><path d="M8 11h8"></path></svg>
        </span>
        <span class="sidebar-export-label">Download series as PDF</span>
      </a>
    {% endif %}
  </div>
{% endif %}
