{% set hasSources = sourceEntries and sourceEntries.length %}
{% set hasIdeas = ideaLabels and ideaLabels.length %}
{% set hasStats = readingStats and readingStats.wordCount > 0 %}

{% if hasSources or hasIdeas or hasStats %}
  <div class="note-meta-strip" aria-label="Note metadata">
    {% if hasSources %}
      {% for source in sourceEntries %}
        <a class="note-meta-pill note-meta-pill-link" href="{{ source.url }}" target="_blank" rel="noopener noreferrer">
          <span class="note-meta-pill-label">Source</span>
          <span class="note-meta-pill-value note-meta-pill-value-with-icon">
            <span class="note-meta-pill-icon" aria-hidden="true">
              {% if source.platform.key == "youtube" %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21.2 7.2a2.9 2.9 0 0 0-2-2c-1.8-.5-7.2-.5-7.2-.5s-5.4 0-7.2.5a2.9 2.9 0 0 0-2 2C2.3 9 2.3 12 2.3 12s0 3 .5 4.8a2.9 2.9 0 0 0 2 2c1.8.5 7.2.5 7.2.5s5.4 0 7.2-.5a2.9 2.9 0 0 0 2-2c.5-1.8.5-4.8.5-4.8s0-3-.5-4.8Z"></path>
                  <path d="m10 15.5 4.5-3.5L10 8.5z" fill="currentColor" stroke="none"></path>
                </svg>
              {% elif source.platform.key == "x" %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 4l16 16"></path>
                  <path d="M20 4 4 20"></path>
                </svg>
              {% elif source.platform.key == "github" %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M9 18c-4 1.2-4-2-5.5-2.4"></path>
                  <path d="M15 18v-3.2a2.8 2.8 0 0 0-.8-2.2c2.6-.3 5.3-1.3 5.3-5.8a4.5 4.5 0 0 0-1.2-3.1 4.2 4.2 0 0 0-.1-3.1s-1-.3-3.2 1.2a11 11 0 0 0-6 0C6.8.3 5.8.6 5.8.6a4.2 4.2 0 0 0-.1 3.1 4.5 4.5 0 0 0-1.2 3.1c0 4.5 2.7 5.5 5.3 5.8A2.8 2.8 0 0 0 9 14.8V18"></path>
                </svg>
              {% else %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="9"></circle>
                  <path d="M3 12h18"></path>
                  <path d="M12 3a15 15 0 0 1 0 18"></path>
                  <path d="M12 3a15 15 0 0 0 0 18"></path>
                </svg>
              {% endif %}
            </span>
            <span>{{ source.label or source.title or source.platform.label or source.url }}</span>
          </span>
        </a>
      {% endfor %}
    {% endif %}

    {% if hasIdeas %}
      {% for idea in ideaLabels %}
        <span class="note-meta-pill">
          <span class="note-meta-pill-label">Idea</span>
          <span class="note-meta-pill-value">{{ idea }}</span>
        </span>
      {% endfor %}
    {% endif %}

    {% if hasStats %}
      <span class="note-meta-pill">
        <span class="note-meta-pill-label">Words</span>
        <span class="note-meta-pill-value note-meta-pill-value-numeric">{{ readingStats.wordCountLabel }}</span>
      </span>
      <span class="note-meta-pill">
        <span class="note-meta-pill-label">Read time</span>
        <span class="note-meta-pill-value note-meta-pill-value-numeric">{{ readingStats.readingTimeLabel }}</span>
      </span>
    {% endif %}
  </div>
{% endif %}
