{% set hasChannel = channelInfo and showChannelMetadata %}
{% set hasIdeas = ideaLabels and ideaLabels.length %}
{% set hasStats = readingStats and readingStats.wordCount > 0 %}
{% set hasAuthor = authorName %}

{% if pageKind == "note" and (hasAuthor or hasChannel or hasIdeas or hasStats) %}
  <div class="note-meta-strip" aria-label="Note metadata">
    {% if hasAuthor or hasChannel or hasIdeas or hasStats %}
      <div class="note-stats-row" aria-label="Reading stats">
        {% if hasAuthor %}
          <span class="note-stat-item">
            <span class="note-stat-label">Author</span>
            <span class="note-stat-value">{{ authorName }}</span>
          </span>
        {% endif %}

        {% if hasChannel %}
          <a class="note-stat-item note-stat-link" href="{{ channelInfo.url if pageKind != 'channel-page' else channelInfo.sourceUrl }}">
            <span class="note-stat-label">Channel</span>
            <span class="note-stat-value note-stat-value-with-avatar">
              {% if channelInfo.logo %}
                <img class="note-channel-avatar" src="{{ channelInfo.logo }}" alt="{{ channelInfo.name }}">
              {% endif %}
              <span>{{ channelInfo.name }}</span>
            </span>
          </a>
        {% endif %}

        {% if hasIdeas %}
          {% for idea in ideaLabels %}
            <span class="note-stat-item">
              <span class="note-stat-label">Idea</span>
              <span class="note-stat-value">{{ idea }}</span>
            </span>
          {% endfor %}
        {% endif %}

        {% if hasStats %}
          <span class="note-stat-item">
            <span class="note-stat-label">Words</span>
            <span class="note-stat-value note-stat-value-numeric">{{ readingStats.wordCountLabel }}</span>
          </span>
          <span class="note-stat-item">
            <span class="note-stat-label">Read time</span>
            <span class="note-stat-value note-stat-value-numeric">{{ readingStats.readingTimeLabel }}</span>
          </span>
        {% endif %}
      </div>
    {% endif %}
  </div>
{% endif %}
