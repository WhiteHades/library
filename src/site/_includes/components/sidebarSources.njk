{% if pageKind == "note" and sourceEntries and sourceEntries.length %}
  <section class="sidebar-sources" aria-label="Sources">
    <div class="sidebar-section-title">Sources</div>
    <div class="sidebar-source-list">
      {% for source in sourceEntries %}
        <a class="sidebar-source-link sidebar-source-link-{{ source.platform.key }}" href="{{ source.url }}" target="_blank" rel="noopener noreferrer">
          <span class="sidebar-source-icon" aria-hidden="true">
            {% if source.platform.key == "youtube" %}
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M23 12.01c0 2.19-.23 4.13-.38 5.09a3.3 3.3 0 0 1-2.7 2.68c-1.06.18-3.92.47-7.92.47-3.99 0-6.85-.29-7.92-.47a3.3 3.3 0 0 1-2.7-2.68C1.24 16.14 1 14.2 1 12.01c0-2.18.24-4.12.38-5.09a3.3 3.3 0 0 1 2.7-2.68c1.07-.18 3.93-.47 7.92-.47 4 0 6.86.29 7.92.47a3.3 3.3 0 0 1 2.7 2.68c.15.97.38 2.91.38 5.09Z" fill="#FF0033"></path>
                <path d="M10 8.5v7l6-3.5-6-3.5Z" fill="#fff"></path>
              </svg>
            {% elif source.platform.key == "x" %}
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18.9 2H22l-6.77 7.74L23.2 22h-6.26l-4.9-7.41L5.56 22H2.45l7.24-8.27L1.8 2h6.42l4.43 6.73L18.9 2Zm-1.1 18h1.73L7.26 3.9H5.4L17.8 20Z"></path>
              </svg>
            {% elif source.platform.key == "github" %}
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.03c-3.34.73-4.05-1.42-4.05-1.42-.55-1.38-1.33-1.74-1.33-1.74-1.08-.74.08-.72.08-.72 1.2.08 1.82 1.22 1.82 1.22 1.05 1.81 2.77 1.29 3.45.99.11-.77.41-1.29.74-1.58-2.67-.31-5.47-1.32-5.47-5.9 0-1.31.47-2.39 1.23-3.24-.12-.3-.53-1.56.12-3.25 0 0 1-.32 3.3 1.23a11.6 11.6 0 0 1 6 0c2.3-1.55 3.3-1.23 3.3-1.23.65 1.69.24 2.95.12 3.25.77.85 1.23 1.93 1.23 3.24 0 4.59-2.8 5.58-5.48 5.89.43.37.81 1.1.81 2.22v3.3c0 .32.22.69.83.58A12 12 0 0 0 12 .5Z"></path>
              </svg>
            {% else %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="9"></circle>
                <path d="M3 12h18"></path>
                <path d="M12 3a15 15 0 0 1 0 18"></path>
                <path d="M12 3a15 15 0 0 0 0 18"></path>
              </svg>
            {% endif %}
          </span>
          <span class="sidebar-source-title">{{ source.title or source.label or source.platform.label or source.url }}</span>
        </a>
      {% endfor %}
    </div>
  </section>
{% endif %}
