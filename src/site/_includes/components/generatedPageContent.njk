{% if pageKind == "channel-index" %}
  <p>This page indexes all source channels currently represented in the public library. Channels are grouped separately from ideas so a reader can browse by provenance when needed.</p>
  <ul>
    {% for channel in publishModel.channels %}
      {% if not channel.hidden %}
        <li><a href="/channels/{{ channel.key }}/">{{ channel.name }}</a></li>
      {% endif %}
    {% endfor %}
  </ul>
{% elif pageKind == "series-index" %}
  <p>This page indexes all reading series currently represented in the public library. Series are grouped separately from ideas and channels so a reader can follow a focused reading path.</p>
  <ul>
    {% for series in publishModel.series %}
      <li><a href="{{ series.url }}">{{ series.title }}</a></li>
    {% endfor %}
  </ul>
{% elif pageKind == "channel-page" %}
  <p>{{ channelInfo.name }} is one of the source channels represented in this public library. This page groups the channel's work by idea first, then by series and standalone notes.</p>
  {% if channelInfo and channelInfo.description %}
    <p>{{ channelInfo.description }}</p>
  {% endif %}
  {% for channelPage in publishModel.channels %}
    {% if channelPage.key == channelInfo.key %}
      {% for idea in channelPage.ideas %}
        <h3>{{ idea.title }}</h3>
        {% if idea.series and idea.series.length %}
          <h4>Series</h4>
          <ul>
            {% for series in idea.series %}
              <li><a href="{{ series.url }}">{{ series.title }}</a></li>
            {% endfor %}
          </ul>
        {% endif %}
        {% if idea.standalone and idea.standalone.length %}
          <h4>Standalone</h4>
          <ul>
            {% for note in idea.standalone %}
              <li><a href="{{ note.url }}">{{ note.title }}</a></li>
            {% endfor %}
          </ul>
        {% endif %}
      {% endfor %}
    {% endif %}
  {% endfor %}
{% elif pageKind == "series-page" %}
  <p>{{ seriesInfo.title }} is an ordered reading path generated from the series registry and note sequence metadata. Use the notes below to read in sequence.</p>
  {% if seriesInfo and seriesInfo.description %}
    <p>{{ seriesInfo.description }}</p>
  {% endif %}
  {% if seriesInfo and seriesInfo.notes and seriesInfo.notes.length %}
    <h3>Reading Path</h3>
    <ul>
      {% for note in seriesInfo.notes %}
        <li><a href="{{ note.url }}">{{ note.title }}</a></li>
      {% endfor %}
    </ul>
  {% endif %}
{% endif %}
