#!/bin/sh
# Skip in CI environments
if [ -n "$CI" ] || [ -n "$VERCEL" ] || [ -n "$GITHUB_ACTIONS" ]; then
  exit 0
fi

# Run tests first
npm test
if [ $? -ne 0 ]; then
  echo "[pre-commit] Tests failed. Aborting commit."
  exit 1
fi

# Check if staged files include notes
STAGED_NOTES=$(git diff --cached --name-only --diff-filter=ACM -- src/site/notes/ 2>/dev/null)
if [ -z "$STAGED_NOTES" ]; then
  exit 0
fi

echo "[pre-commit] Note changes staged. Regenerating PDFs..."

# Run the full build to regenerate PDFs
npm run build
if [ $? -ne 0 ]; then
  echo "[pre-commit] Build failed. Aborting commit."
  exit 1
fi

# Stage any updated PDFs so they are included in this commit
PDF_CHANGES=$(git status --porcelain src/site/pdf/ 2>/dev/null)
if [ -n "$PDF_CHANGES" ]; then
  echo "[pre-commit] Staging updated PDFs..."
  git add src/site/pdf/
fi

exit 0
